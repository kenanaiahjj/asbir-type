feature cpsp {
    # notes:
    # The first two numbers (16 and 0) are the x and y amounts by which a glyph is moved. The second pair of numbers (32 and 0) is the advance, meaning that the cursor will be placed 32 units further in this case. Effectively, this adds 16 units on each side (or 32 between all uppercase letters)
    # The first two numbers (16 and 0) are the x and y amounts by which a glyph is moved.
    # The second pair of numbers (32 and 0) is the advance, meaning that the cursor will
    # be placed 32 units further in this case. Effectively, this adds 16 units on each side
    # (or 32 between all uppercase letters)
    pos @Uppercase <16 0 32 0>;
} cpsp;

feature ordn {
    # automatic
    sub [zero one two three four five six seven eight nine] [A a]' by ordfeminine;
    sub [zero one two three four five six seven eight nine] [O o]' by ordmasculine;
    sub N o period by numero;
} ordn;

