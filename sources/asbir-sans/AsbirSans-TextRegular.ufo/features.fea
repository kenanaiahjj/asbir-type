feature locl {
    # automatic
    lookup locl_latn_0 {
        script latn;
        language ROM;
        sub Scedilla by Scommaaccent;
        sub scedilla by scommaaccent;
        sub tcedilla by tcommaaccent;
        language MOL;
        sub Scedilla by Scommaaccent;
        sub scedilla by scommaaccent;
        sub tcedilla by tcommaaccent;
    } locl_latn_0;

    lookup locl_latn_1 {
        script latn;
        language CAT;
        sub l' periodcentered' l by ldot;
        sub L' periodcentered' L by Ldot;
    } locl_latn_1;

} locl;

