# Prefix: Languagesystems
languagesystem DFLT dflt;
languagesystem latn dflt;
languagesystem latn ROM;
languagesystem latn MOL;
languagesystem latn CAT;
# Prefix: Subs
# used by ss05
lookup sub_tt2 {
    sub t by t.1;
} sub_tt2;

feature aalt {
    # automatic
    feature locl;
    feature sinf;
    feature numr;
    feature dnom;
    feature case;
    feature subs;
    feature sups;
    feature pnum;
    feature tnum;
    feature ordn;
    feature ss03;
    feature ss07;
    feature ss08;
} aalt;

